PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
COOKIE_DOMAIN=

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/ai_assessment?retryWrites=true&w=majority

# Upstash Redis connection string (TLS — starts with rediss://)
# Format: rediss://:PASSWORD@HOST:PORT
UPSTASH_REDIS_URL=rediss://:YOUR_PASSWORD@YOUR_HOST.upstash.io:6379

# Google Gemini API key
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Cloudinary credentials
CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# JWT auth
JWT_SECRET=YOUR_STRONG_RANDOM_SECRET
JWT_EXPIRY=7d
